# =============================================================================
# GolfGives — Environment Variables Template
# =============================================================================
#
# INSTRUCTIONS:
#   1. Copy this file to .env.local for local development
#   2. Fill in every value — the app will refuse to start with missing vars
#   3. Add all variables to Vercel: Settings → Environment Variables
#   4. NEVER commit .env.local — it is listed in .gitignore
#
# =============================================================================

# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API keys
# Use sk_test_ / pk_test_ for development, sk_live_ / pk_live_ for production

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Stripe Dashboard → Products → your product → Pricing
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_your_monthly_price_id
NEXT_PUBLIC_STRIPE_YEARLY_PRICE_ID=price_your_yearly_price_id

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# https://resend.com → API Keys

RESEND_API_KEY=re_your_resend_api_key

# Must be a verified sender domain in Resend
# During development you can use onboarding@resend.dev (delivers to account owner only)
EMAIL_FROM=noreply@yourdomain.com

# ─── App ─────────────────────────────────────────────────────────────────────
# No trailing slash
# Development: http://localhost:3000
# Production:  https://your-vercel-app.vercel.app

NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# OPTIONAL
# =============================================================================

# Google OAuth (Supabase Dashboard → Authentication → Providers → Google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
